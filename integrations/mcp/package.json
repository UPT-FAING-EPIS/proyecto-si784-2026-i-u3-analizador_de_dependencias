{
  "name": "@depanalyzer/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "depanalyzer-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "cross-spawn": "^7.0.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "25.9.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
