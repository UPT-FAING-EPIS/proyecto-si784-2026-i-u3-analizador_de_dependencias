{
  "name": "depanalyzer-vscode",
  "displayName": "DepAnalyzer Security",
  "description": "Detecta dependencias vulnerables y desactualizadas desde Visual Studio Code.",
  "version": "0.4.0",
  "publisher": "DepAnalyzerUPT",
  "license": "MIT",
  "icon": "resources/depanalyzer.png",
  "preview": false,
  "pricing": "Free",
  "homepage": "https://upt-faing-epis.github.io/proyecto-si784-2026-i-u2-analizador-de-dependencias-2/",
  "bugs": {
    "url": "https://github.com/UPT-FAING-EPIS/proyecto-si784-2026-i-u2-analizador-de-dependencias-2/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/UPT-FAING-EPIS/proyecto-si784-2026-i-u2-analizador-de-dependencias-2.git",
    "directory": "integrations/vscode"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "dependencies",
    "dependency",
    "security",
    "vulnerability",
    "cve",
    "maven",
    "gradle",
    "npm",
    "python",
    "sca",
    "depanalyzer"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:pom.xml",
    "workspaceContains:build.gradle",
    "workspaceContains:build.gradle.kts",
    "workspaceContains:package.json",
    "workspaceContains:pyproject.toml",
    "workspaceContains:requirements.txt",
    "onCommand:depanalyzer.scanWorkspace",
    "onCommand:depanalyzer.scanFile",
    "onCommand:depanalyzer.clearDiagnostics",
    "onCommand:depanalyzer.showFindingDetails",
    "onCommand:depanalyzer.openFindingLocation",
    "onCommand:depanalyzer.openFindingReference",
    "onCommand:depanalyzer.manageUpdates",
    "onCommand:depanalyzer.filterDependencyTree",
    "onCommand:depanalyzer.guideCliUpgrade",
    "onCommand:depanalyzer.redetectCli",
    "onCommand:depanalyzer.showOutput",
    "onCommand:depanalyzer.openDashboard",
    "onCommand:depanalyzer.configureOssIndex"
  ],
  "contributes": {
    "commands": [
      {
        "command": "depanalyzer.scanWorkspace",
        "title": "DepAnalyzer: Analizar Workspace",
        "category": "DepAnalyzer",
        "icon": "$(play)"
      },
      {
        "command": "depanalyzer.openDashboard",
        "title": "DepAnalyzer: Abrir Dashboard",
        "category": "DepAnalyzer",
        "icon": "$(dashboard)"
      },
      {
        "command": "depanalyzer.configureOssIndex",
        "title": "DepAnalyzer: Configurar OSS Index",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.scanFile",
        "title": "DepAnalyzer: Analizar Archivo Actual",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.clearDiagnostics",
        "title": "DepAnalyzer: Limpiar Diagnosticos",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.showFindingDetails",
        "title": "DepAnalyzer: Ver Detalle",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.openFindingLocation",
        "title": "DepAnalyzer: Abrir Archivo",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.openFindingReference",
        "title": "DepAnalyzer: Ver Referencia CVE",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.manageUpdates",
        "title": "DepAnalyzer: Gestionar Actualizaciones",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.filterDependencyTree",
        "title": "DepAnalyzer: Filtrar Arbol",
        "category": "DepAnalyzer",
        "icon": "$(filter)"
      },
      {
        "command": "depanalyzer.guideCliUpgrade",
        "title": "DepAnalyzer: Actualizar CLI",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.redetectCli",
        "title": "DepAnalyzer: Volver a Detectar CLI",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.showOutput",
        "title": "DepAnalyzer: Mostrar Salida",
        "category": "DepAnalyzer"
      },
      {
        "command": "depanalyzer.applyUpdate",
        "title": "DepAnalyzer: Preparar Actualizacion",
        "category": "DepAnalyzer"
      }
    ],
    "configuration": {
      "title": "DepAnalyzer",
      "properties": {
        "depanalyzer.executablePath": {
          "type": "string",
          "default": "",
          "description": "Ruta al ejecutable depanalyzer. Si queda vacia, se busca la distribucion local y luego PATH."
        },
        "depanalyzer.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Analiza automaticamente el workspace al activar la extension."
        },
        "depanalyzer.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Reanaliza al guardar archivos de dependencias."
        },
        "depanalyzer.dynamic": {
          "type": "boolean",
          "default": false,
          "description": "Configuracion anterior de analisis dinamico.",
          "deprecationMessage": "Usa depanalyzer.analysisMode."
        },
        "depanalyzer.analysisMode": {
          "type": "string",
          "enum": [
            "ask",
            "precise",
            "fast"
          ],
          "enumDescriptions": [
            "Pregunta una vez por workspace.",
            "Ejecuta Maven/Gradle para resolver versiones, transitivas y cadenas.",
            "Analiza solo los archivos declarados, sin ejecutar el build."
          ],
          "default": "ask",
          "description": "Nivel de precision para Maven y Gradle."
        },
        "depanalyzer.provider": {
          "type": "string",
          "enum": [
            "auto",
            "oss",
            "nvd"
          ],
          "default": "auto",
          "description": "Fuente de vulnerabilidades usada por el CLI."
        },
        "depanalyzer.timeoutSeconds": {
          "type": "number",
          "default": 1800,
          "minimum": 10,
          "maximum": 3600,
          "description": "Timeout del analisis en segundos."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "depanalyzer",
          "title": "DepAnalyzer",
          "icon": "resources/depanalyzer.svg"
        }
      ]
    },
    "views": {
      "depanalyzer": [
        {
          "id": "depanalyzer.summary",
          "name": "Resumen",
          "type": "webview",
          "contextualTitle": "DepAnalyzer Security"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "depanalyzer.scanWorkspace",
          "when": "view == depanalyzer.summary",
          "group": "navigation"
        },
        {
          "command": "depanalyzer.openDashboard",
          "when": "view == depanalyzer.summary",
          "group": "navigation@2"
        },
        {
          "command": "depanalyzer.clearDiagnostics",
          "when": "view == depanalyzer.summary",
          "group": "2_cleanup"
        }
      ],
      "view/item/context": [
        {
          "command": "depanalyzer.showFindingDetails",
          "when": "view == depanalyzer.findings && viewItem =~ /depanalyzer\\.finding/",
          "group": "inline@1"
        },
        {
          "command": "depanalyzer.openFindingLocation",
          "when": "view == depanalyzer.findings && viewItem =~ /location/",
          "group": "inline@2"
        },
        {
          "command": "depanalyzer.openFindingReference",
          "when": "view == depanalyzer.findings && viewItem =~ /reference/",
          "group": "navigation@1"
        },
        {
          "command": "depanalyzer.manageUpdates",
          "when": "view == depanalyzer.findings && viewItem =~ /update/",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "test": "npm run build && node --test dist/**/*.test.js",
    "bundle:cli": "node scripts/prepare-cli.mjs",
    "package": "npm run bundle:cli && vsce package",
    "publish": "npm run bundle:cli && vsce publish"
  },
  "dependencies": {
    "cross-spawn": "7.0.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/node": "25.9.3",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "3.9.2",
    "typescript": "6.0.3"
  }
}
